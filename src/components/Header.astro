---
---

<header class="site-header">
  <div class="container">
    <div class="header-row">
      <a href="/" class="wordmark" aria-label="CloudBridge Networks home">
        <span class="wordmark-mark" aria-hidden="true">
          <svg viewBox="0 0 48 48" class="wordmark-icon" role="presentation">
            <rect x="0" y="0" width="48" height="48" rx="12" class="wordmark-tile"></rect>
            <path
              d="M31.9 30H16.2C13.9 30 12 28.2 12 25.9C12 23.8 13.6 22.1 15.6 21.9C16.4 18.6 19.3 16.2 22.8 16.2C25.6 16.2 28.2 17.7 29.5 20.1C29.7 20 29.9 20 30.2 20C32.7 20 34.8 22.1 34.8 24.6C34.8 24.9 34.7 25.2 34.7 25.4C36.1 26 37 27.3 37 28.8C37 30.9 35.3 32.6 33.2 32.6H16.2C13.9 32.6 12 30.8 12 28.5V28.4C12 28.2 12.1 28.1 12.1 28H31.9Z"
              fill="white"
            ></path>
          </svg>
        </span>
        <span class="wordmark-copy">
          <span class="wordmark-text">CloudBridge</span>
          <span class="wordmark-note">Networks</span>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Primary">
        <a href="/#mission">Why us</a>
        <a href="/#infrastructure">What we build</a>
        <a href="/#operations">How we operate</a>
        <a href="/about">Company</a>
        <a href="/contact">Contact</a>
      </nav>

      <a href="/contact" class="btn btn-primary header-cta">Talk to our team</a>
      <button
        type="button"
        class="menu-button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open navigation"
        data-menu-toggle
      >
        <span class="menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
        <span class="sr-only">Toggle navigation</span>
      </button>
    </div>

    <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile" hidden>
      <a href="/#mission">Why us</a>
      <a href="/#infrastructure">What we build</a>
      <a href="/#operations">How we operate</a>
      <a href="/about">Company</a>
      <a href="/contact">Contact</a>
      <a href="/contact" class="btn btn-primary btn-block">Talk to our team</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const mobileNav = document.getElementById('mobile-nav');

  if (toggle && mobileNav) {
    const setExpandedState = (expanded) => {
      toggle.setAttribute('aria-expanded', String(expanded));
      toggle.setAttribute('aria-label', expanded ? 'Close navigation' : 'Open navigation');
      toggle.dataset.open = String(expanded);
      mobileNav.hidden = !expanded;
    };

    setExpandedState(false);

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      setExpandedState(!expanded);
    });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        setExpandedState(false);
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-background);
  }

  .site-header .container {
    width: min(calc(100% - 24px), 1360px);
  }

  .header-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: var(--space-8);
    min-height: 72px;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    text-decoration: none;
    font-weight: 600;
    min-width: 0;
    grid-column: 1;
    justify-self: start;
  }

  .wordmark-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .wordmark-icon {
    width: 40px;
    height: 40px;
  }

  .wordmark-tile {
    fill: var(--color-accent);
  }

  .wordmark-copy {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .wordmark-text {
    color: var(--color-text);
    line-height: 1.1;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }

  .wordmark-note {
    color: var(--color-subtle);
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.1;
    white-space: nowrap;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: var(--space-32);
    justify-self: center;
  }

  .desktop-nav a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .desktop-nav a:hover,
  .desktop-nav a:focus-visible {
    color: var(--color-text);
  }

  .header-cta,
  .menu-button {
    min-height: 40px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
  }

  .header-cta {
    display: inline-flex;
    flex-shrink: 0;
    padding: 10px var(--space-12);
    font-size: 0.875rem;
    white-space: nowrap;
    grid-column: 3;
    justify-self: end;
  }

  .menu-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    padding: 0;
    background: transparent;
    flex-shrink: 0;
    color: var(--color-text);
    grid-column: 2;
    justify-self: end;
  }

  .mobile-nav {
    display: grid;
    gap: var(--space-12);
    padding: 0 0 var(--space-16);
  }

  .mobile-nav[hidden] {
    display: none;
  }

  .mobile-nav a {
    text-decoration: none;
    color: var(--color-muted);
  }

  .mobile-nav a:hover,
  .mobile-nav a:focus-visible {
    color: var(--color-text);
  }

  .menu-icon {
    display: inline-grid;
    gap: 5px;
  }

  .menu-icon span {
    display: block;
    width: 16px;
    height: 2px;
    background: currentColor;
  }

  .menu-button[data-open='true'] .menu-icon span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .menu-button[data-open='true'] .menu-icon span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 960px) {
    .site-header .container {
      width: min(calc(100% - 40px), 1400px);
    }

    .header-row {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: var(--space-16);
      min-height: 80px;
    }

    .wordmark {
      gap: var(--space-12);
      justify-self: start;
    }

    .wordmark-mark,
    .wordmark-icon {
      width: 44px;
      height: 44px;
    }

    .wordmark-text {
      font-size: 1.25rem;
    }

    .wordmark-note {
      font-size: 0.82rem;
    }

    .desktop-nav {
      display: flex;
      grid-column: 2;
      justify-self: center;
    }

    .header-cta {
      grid-column: 3;
      justify-self: end;
      padding: var(--space-12) var(--space-16);
      font-size: 0.95rem;
    }

    .menu-button,
    .mobile-nav {
      display: none;
    }
  }

  @media (max-width: 959px) {
    .desktop-nav {
      display: none;
    }

    .header-cta {
      justify-self: end;
    }

    .mobile-nav {
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-16);
    }

    .mobile-nav .btn {
      min-height: 40px;
    }
  }

  @media (max-width: 420px) {
    .wordmark-note {
      display: none;
    }

    .wordmark-mark,
    .wordmark-icon {
      width: 36px;
      height: 36px;
    }

    .header-cta {
      padding-inline: 10px;
      font-size: 0.82rem;
    }
  }
</style>
