---
// Footer.astro - Reusable footer component for all pages
// Includes navigation, contact, social, and legal links
---

<footer class="footer">
  <div class="container">
    
    <!-- Main Footer Content -->
    <div class="footer-grid">
      
      <!-- Column 1: Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-icon" aria-hidden="true">🌐</span>
          <span class="logo-text">CloudBridge Networks</span>
        </a>
        <p class="brand-tagline">
          Building Connected Africa, One Hotspot at a Time
        </p>
        <div class="brand-contact">
          <p class="contact-item">
            <span class="contact-icon" aria-hidden="true">📍</span>
            Nairobi, Kenya
          </p>
          <p class="contact-item">
            <span class="contact-icon" aria-hidden="true">📧</span>
            <a href="mailto:hello@cloudbridge.network">hello@cloudbridge.network</a>
          </p>
          <p class="contact-item">
            <span class="contact-icon" aria-hidden="true">📱</span>
            <a href="tel:+254742939094">+254 742 939 094</a>
          </p>
        </div>
      </div>
      
      <!-- Column 2: Product Links -->
      <div class="footer-links">
        <h4 class="footer-heading">Product</h4>
        <ul class="footer-list">
          <li><a href="#features">Features</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="/contact">Contact Us</a></li>
          <li><a href="https://app.cloudbridge.network" target="_blank" rel="noopener">Login</a></li>
        </ul>
      </div>
      
      <!-- Column 3: Company Links -->
      <div class="footer-links">
        <h4 class="footer-heading">Company</h4>
        <ul class="footer-list">
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="https://twitter.com/cloudbridgeke" target="_blank" rel="noopener">Blog</a></li>
          <li><a href="/careers">Careers</a></li>
        </ul>
      </div>
      
      <!-- Column 4: Legal & Social -->
      <div class="footer-links">
        <h4 class="footer-heading">Legal</h4>
