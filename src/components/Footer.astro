    </div>
    
    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <p class="copyright">
          &copy; 2026 CloudBridge Networks. All rights reserved.
        </p>
        <p class="registration-info">
          Registered in Kenya: BN-Y6S98MJB | Nairobi
        </p>
      </div>
      <div class="footer-badges">
        <span class="badge">🇰🇪 Made in Kenya</span>
        <span class="badge">🌍 Built for Africa</span>
      </div>
    </div>
    
  </div>
</footer>

<style>
  /* ──────────────────────────────────────────────────────────────────
     FOOTER LAYOUT
     ────────────────────────────────────────────────────────────────── */
  .footer {
    background: var(--color-dark);
    color: var(--color-gray-300);
    padding: 4rem 0 2rem;
    font-size: 0.9375rem;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     BRAND COLUMN
     ────────────────────────────────────────────────────────────────── */
  .footer-brand {
    max-width: 300px;
  }
  
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.25rem;
    color: white;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  
  .footer-logo:hover {
    color: var(--color-primary-light);
  }
  
  .logo-icon {
    font-size: 1.5rem;
  }
  
  .brand-tagline {
    color: var(--color-gray-400);
    font-size: 0.875rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  
  .brand-contact {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-gray-400);
    margin: 0;
  }
  
  .contact-icon {
    flex-shrink: 0;
  }
  
  .contact-item a {
    color: var(--color-gray-300);
    transition: var(--transition);
  }
  
  .contact-item a:hover {
    color: white;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     LINKS COLUMNS
     ────────────────────────────────────────────────────────────────── */
  .footer-heading {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 1.25rem;
  }
  
  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .footer-list li a {
    color: var(--color-gray-400);
    text-decoration: none;
    transition: var(--transition);
    font-size: 0.9375rem;
  }
  
  .footer-list li a:hover {
    color: white;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     SOCIAL LINKS
     ────────────────────────────────────────────────────────────────── */
  .footer-social {
    margin-top: 2rem;
  }
  
  .social-links {
    display: flex;
    gap: 1rem;
  }
  
  .social-link {
    width: 40px;
    height: 40px;
    background: var(--color-gray-800);
    border-radius: var(--border-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-400);
    transition: var(--transition);
  }
  
  .social-link:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }
  
  /* ──────────────────────────────────────────────────────────────────
     BOTTOM BAR
     ────────────────────────────────────────────────────────────────── */
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--color-gray-800);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    text-align: center;
  }
  
  .footer-bottom-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .copyright {
    color: var(--color-gray-500);
    font-size: 0.875rem;
    margin: 0;
  }
  
  .registration-info {
    color: var(--color-gray-600);
    font-size: 0.8125rem;
    margin: 0;
  }
  
  .footer-badges {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .badge {
    font-size: 0.75rem;
    color: var(--color-gray-500);
    background: var(--color-gray-800);
    padding: 0.375rem 0.75rem;
    border-radius: 2rem;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     RESPONSIVE BREAKPOINTS
     ────────────────────────────────────────────────────────────────── */
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
    
    .footer-bottom-content {
      flex-direction: row;
      gap: 2rem;
      align-items: center;
    }
  }
  
  @media (min-width: 1024px) {
    .footer {
      padding: 5rem 0 2rem;
    }
    
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 4rem;
    }
    
    .footer-brand {
      max-width: none;
    }
  }
  
  @media (max-width: 639px) {
    .footer {
      padding: 3rem 0 1.5rem;
    }
    
    .footer-grid {
      gap: 2rem;
    }
    
    .social-links {
      justify-content: flex-start;
    }
  }
</style>