<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-48) 0;
  }

  .footer-grid {
    display: grid;
    gap: var(--space-32);
  }

  .footer-block h2 {
    margin-bottom: var(--space-12);
    font-size: 1rem;
    letter-spacing: 0;
  }

  .footer-block .eyebrow {
    margin-bottom: var(--space-12);
  }

  .footer-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-8);
  }

  .footer-bottom {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-32);
    padding-top: var(--space-24);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1.5fr) repeat(2, minmax(0, 1fr));
    }

    .footer-bottom {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: center;
    }
  }
</style>
