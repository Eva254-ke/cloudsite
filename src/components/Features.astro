---
// Features.astro - Homepage features section
// Shows 6 key features in a responsive grid
---

<section class="features-section" id="features">
  <div class="container">
    
    <!-- Section Header -->
    <div class="section-header">
      <h2 class="section-title">
        Infrastructure Capabilities Built for<br />
        <span class="text-primary">Scale Across Africa</span>
      </h2>
      <p class="section-subtitle">
        From satellite backhaul and router orchestration to payments and analytics,
        CloudBridge provides the operational stack for modern connectivity providers.
      </p>
    </div>
    
    <!-- Features Grid -->
    <div class="features-grid">
      
      <!-- Feature 1: Starlink Integration -->
      <div class="feature-card">
        <div class="feature-icon-wrapper">
          <span class="feature-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 4v4" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M8.5 10.5a5 5 0 0 1 7 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M6 8a8.5 8.5 0 0 1 12 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 16.5h.01" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <h3 class="feature-title">Starlink Integration</h3>
        <p class="feature-description">
          Reliable satellite backhaul anywhere in Africa. We monitor uptime and data usage automatically, so you never lose customers to outages.
        </p>
        <ul class="feature-list">
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Automatic uptime monitoring
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Data usage alerts
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Works in rural areas
          </li>
        </ul>
      </div>
      
      <!-- Feature 2: MikroTik Management -->
      <div class="feature-card">
        <div class="feature-icon-wrapper">
          <span class="feature-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8 4v5" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M16 4v5" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M6 10h12v2a6 6 0 0 1-6 6 6 6 0 0 1-6-6v-2Z" fill="white" fill-opacity="0.25"/>
              <path d="M12 18v2" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <h3 class="feature-title">MikroTik Management</h3>
        <p class="feature-description">
          Remote router control from your dashboard. Create sessions, disconnect users, manage bandwidth — all without touching the physical router.
        </p>
        <ul class="feature-list">
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Remote configuration
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Auto session activation
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Bandwidth management
          </li>
        </ul>
      </div>
      
      <!-- Feature 3: M-Pesa Billing -->
      <div class="feature-card">
        <div class="feature-icon-wrapper">
          <span class="feature-icon" aria-hidden="true">
            <!-- Credit Card SVG -->
            <svg width="32" height="32" fill="none" viewBox="0 0 32 32" aria-hidden="true"><rect x="3" y="7" width="26" height="18" rx="4" fill="#10b981"/><rect x="3" y="13" width="26" height="3" fill="#fff"/><rect x="8" y="21" width="6" height="3" rx="1.5" fill="#fff"/></svg>
          </span>
        </div>
        <h3 class="feature-title">M-Pesa Billing</h3>
        <p class="feature-description">
          Accept payments via STK Push or manual M-Pesa. Money goes directly to your Till. We track transactions and calculate commission automatically.
        </p>
        <ul class="feature-list">
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            STK Push integration
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Manual payment tracking
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Auto commission calculation
          </li>
        </ul>
      </div>
      
      <!-- Feature 4: Captive Portal -->
      <div class="feature-card">
        <div class="feature-icon-wrapper">
          <span class="feature-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="7" y="3.5" width="10" height="17" rx="2" stroke="white" stroke-width="2"/>
              <path d="M11 6h2" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M10.5 17h3" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <h3 class="feature-title">Captive Portal</h3>
        <p class="feature-description">
          Professional WiFi login page for your customers. Customizable branding, package selection, and voucher redemption — all mobile-optimized.
        </p>
        <ul class="feature-list">
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Custom branding
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Mobile-optimized
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Voucher support
          </li>
        </ul>
      </div>
      
      <!-- Feature 5: Analytics Dashboard -->
      <div class="feature-card">
        <div class="feature-icon-wrapper">
          <span class="feature-icon" aria-hidden="true">
            <!-- Analytics/Bar Chart SVG -->
            <svg width="32" height="32" fill="none" viewBox="0 0 32 32" aria-hidden="true"><rect x="6" y="18" width="4" height="8" rx="2" fill="#3b82f6"/><rect x="14" y="12" width="4" height="14" rx="2" fill="#3b82f6"/><rect x="22" y="7" width="4" height="19" rx="2" fill="#3b82f6"/></svg>
          </span>
        </div>
        <h3 class="feature-title">Analytics Dashboard</h3>
        <p class="feature-description">
          Real-time visibility into revenue, active users, router health, and growth trends. Make data-driven decisions to scale your business.
        </p>
        <ul class="feature-list">
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Revenue tracking
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            User analytics
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Router health monitoring
          </li>
        </ul>
      </div>
      
      <!-- Feature 6: Local Support -->
      <div class="feature-card">
        <div class="feature-icon-wrapper">
          <span class="feature-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 12a8 8 0 1 1 16 0" stroke="white" stroke-width="2"/>
              <rect x="3" y="12" width="4" height="6" rx="1.5" fill="white"/>
              <rect x="17" y="12" width="4" height="6" rx="1.5" fill="white"/>
              <path d="M12 20h2.5a2 2 0 0 0 2-2" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <h3 class="feature-title">Local Support</h3>
        <p class="feature-description">
          Nairobi-based team that understands African challenges. We respond in hours, not days. Phone, WhatsApp, and email support available.
        </p>
        <ul class="feature-list">
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Nairobi-based team
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            Response in hours
          </li>
          <li>
            <span class="check-icon" aria-hidden="true">✓</span>
            WhatsApp support
          </li>
        </ul>
      </div>
      
    </div>
    
  </div>
</section>

<style>
  /* ──────────────────────────────────────────────────────────────────
     FEATURES SECTION LAYOUT
     ────────────────────────────────────────────────────────────────── */
  .features-section {
    padding: 3rem 0;
    background: #ffffff;
  }
  
  .section-header {
    text-align: left;
    max-width: 700px;
    margin: 0 auto 1.5rem;
  }
  
  .section-title {
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }
  
  .section-subtitle {
    font-size: 0.98rem;
    color: var(--color-gray-600);
    margin-bottom: 0;
    line-height: 1.6;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     FEATURES GRID
     ────────────────────────────────────────────────────────────────── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     FEATURE CARD
     ────────────────────────────────────────────────────────────────── */
  .feature-card {
    background: #ffffff;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--border-radius-lg);
    padding: 1.1rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  }
  
  @media (hover: hover) and (pointer: fine) {
    .feature-card:hover {
      border-color: var(--color-primary-light);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
  }
  
  .feature-icon-wrapper {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    border-radius: var(--border-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.85rem;
    box-shadow: var(--shadow-sm);
  }
  
  .feature-title {
    font-size: 1.02rem;
    margin-bottom: 0.45rem;
  }
  
  .feature-description {
    font-size: 0.89rem;
    color: var(--color-gray-600);
    margin-bottom: 0.8rem;
    line-height: 1.6;
  }
  
  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  
  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.84rem;
    color: var(--color-gray-700);
    line-height: 1.45;
  }
  
  .check-icon {
    width: 16px;
    height: 16px;
    background: var(--color-accent);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     RESPONSIVE BREAKPOINTS
     ────────────────────────────────────────────────────────────────── */
  @media (min-width: 700px) {
    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.1rem;
    }

    .section-header {
      text-align: center;
      margin-bottom: 2rem;
    }
  }
  
  @media (min-width: 1024px) {
    .features-section {
      padding: 5rem 0;
    }
    
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.1rem;
    }
    
    .section-header {
      margin-bottom: 2.5rem;
    }

    .feature-card {
      padding: 1.25rem;
    }
  }
  
  @media (max-width: 699px) {
    .section-title {
      font-size: 2rem;
    }
    
    .section-subtitle {
      font-size: 1rem;
    }
  }
  
</style>
