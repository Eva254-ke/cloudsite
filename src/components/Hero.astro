---
// Hero.astro - Main homepage hero section
// First impression for visitors - must be compelling and clear
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      
      <!-- Left: Content -->
      <div class="hero-content">
        
        <!-- Badge (Optional - for launches, announcements) -->
        <!-- No badge: removed launch/waitlist messaging -->
        
        <!-- Main Headline -->
        <h1 class="hero-title animate-fade-in-up">
          Pioneering Africa's Digital Future<br />
          <span class="text-primary">Infrastructure at Scale</span>
        </h1>
        
        <!-- Subheadline -->
        <p class="hero-subtitle animate-fade-in-up" style="animation-delay: 0.1s;">
          We design, deploy, and manage next-generation internet infrastructure—leveraging Starlink and advanced wireless technologies to connect cities, towns, and rural communities across Africa. Our mission: affordable, reliable, high-speed connectivity for everyone.
        </p>
        
        <!-- CTA Buttons -->
        <div class="hero-cta animate-fade-in-up" style="animation-delay: 0.2s;">
          <a href="/contact" class="btn btn-primary btn-lg">
            Partner With Us
          </a>
          <a href="#features" class="btn btn-secondary btn-lg">
            Our Solutions
          </a>
        </div>
        
        <!-- Trust Indicators -->
        <div class="hero-trust animate-fade-in-up" style="animation-delay: 0.3s;">
          <p class="trust-text">
            <span class="trust-icon" aria-hidden="true">✓</span>
            Delivering connectivity in Nairobi, Mombasa, Kisumu & beyond
          </p>
          <div class="trust-stats">
            <div class="stat">
              <span class="stat-number">100+</span>
              <span class="stat-label">Sites Deployed</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">99.99%</span>
              <span class="stat-label">Network Uptime</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">24/7</span>
              <span class="stat-label">Support</span>
            </div>
          </div>
        </div>
        
      </div>
      
      <!-- Right: Visual (Illustration/Image Placeholder) -->
      <div class="hero-visual animate-fade-in" style="animation-delay: 0.2s;">
        <div class="hero-image-wrapper" style="position:relative;">
          <img
            class="hero-image"
            src="https://www.ookla.com/s/media/2025/04/tarlink-Impact-on-SSA-fixed-Market-Header-1200x630.jpg" 
            alt="Starlink's Impact on Sub-Saharan Africa Fixed Market" 
            loading="lazy"
          />
          <!-- Floating Cards (Decorative - shows platform features) -->
          <div class="floating-card card-1">
            <span class="card-icon" aria-hidden="true">
              <!-- Credit Card SVG -->
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="3" fill="#10b981"/><rect x="2" y="9" width="20" height="2" fill="#fff"/><rect x="6" y="15" width="4" height="2" rx="1" fill="#fff"/></svg>
            </span>
            <span class="card-text">M-Pesa Billing</span>
          </div>
          <div class="floating-card card-2">
            <span class="card-icon" aria-hidden="true">📶</span>
            <span class="card-text">WiFi Management</span>
          </div>
          <div class="floating-card card-3">
            <span class="card-icon" aria-hidden="true">
              <!-- Analytics/Bar Chart SVG -->
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="13" width="3" height="7" rx="1.5" fill="#3b82f6"/><rect x="10.5" y="9" width="3" height="11" rx="1.5" fill="#3b82f6"/><rect x="17" y="5" width="3" height="15" rx="1.5" fill="#3b82f6"/></svg>
            </span>
            <span class="card-text">Analytics</span>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  // Optional: Add scroll-based animations when hero comes into view
  // This is minimal JS for enhanced UX
  
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
      }
    });
  }, observerOptions);
  
  document.querySelectorAll('.animate-fade-in, .animate-fade-in-up').forEach(el => {
    observer.observe(el);
  });
</script>

<style>
  /* ──────────────────────────────────────────────────────────────────
     HERO SECTION LAYOUT
     ────────────────────────────────────────────────────────────────── */
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(135deg, var(--color-gray-50) 0%, #ffffff 100%);
    overflow: hidden;
    position: relative;
  }
  
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  
  /* ──────────────────────────────────────────────────────────────────
     HERO CONTENT (Left Side)
     ────────────────────────────────────────────────────────────────── */
  .hero-content {
    max-width: 680px;
  }
  
  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, var(--color-secondary) 0%, #fb923c 100%);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-md);
  }
  
  .badge-icon {
    font-size: 1rem;
  }
  
  /* Title */
  .hero-title {
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }
  
  /* Subtitle */
  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    color: var(--color-gray-600);
  }
  
  /* CTA Buttons */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  
  .btn-icon {
    flex-shrink: 0;
  }
  
  /* Trust Indicators */
  .hero-trust {
    padding-top: 2rem;
    border-top: 1px solid var(--color-gray-200);
  }
  
  .trust-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-gray-600);
    margin-bottom: 1.5rem;
  }
  
  .trust-icon {
    color: var(--color-accent);
    font-weight: 700;
  }
  
  .trust-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  
  .stat {
    display: flex;
    flex-direction: column;
  }
  
  .stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }
  
  .stat-label {
    font-size: 0.75rem;
    color: var(--color-gray-500);
    margin-top: 0.25rem;
  }
  
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-gray-300);
  }
  
  /* ──────────────────────────────────────────────────────────────────
     HERO VISUAL (Right Side)
     ────────────────────────────────────────────────────────────────── */
  .hero-visual {
    position: relative;
    align-self: start;
    display: flex;
    justify-content: flex-end;
  }
  
  .hero-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 620px;
    margin: 0 0 0 auto;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16/10;
    border-radius: 1.5rem;
    box-shadow: 0 8px 32px rgba(30, 58, 138, 0.12);
    object-fit: cover;
  }
  
  .hero-image-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  
  .placeholder-content {
    text-align: center;
    color: white;
  }
  
  .placeholder-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 1rem;
    opacity: 0.9;
  }
  
  .placeholder-content p {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: white;
  }
  
  .placeholder-content small {
    font-size: 0.875rem;
    opacity: 0.8;
    color: white;
  }
  
  /* Floating Cards (Decorative) */
  .floating-card {
    position: absolute;
    background: white;
    padding: 0.75rem 1rem;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-700);
    animation: float 3s ease-in-out infinite;
  }
  
  .card-icon {
    font-size: 1.25rem;
  }
  
  .card-1 {
    top: 10%;
    left: -10%;
    animation-delay: 0s;
  }
  
  .card-2 {
    top: 50%;
    right: -15%;
    animation-delay: 1s;
  }
  
  .card-3 {
    bottom: 10%;
    left: -5%;
    animation-delay: 2s;
  }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  
  /* ──────────────────────────────────────────────────────────────────
     ANIMATIONS (Respect user preferences)
     ────────────────────────────────────────────────────────────────── */
  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
  }
  
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in,
    .animate-fade-in-up,
    .floating-card {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
  
  /* ──────────────────────────────────────────────────────────────────
     RESPONSIVE BREAKPOINTS
     ────────────────────────────────────────────────────────────────── */
  @media (min-width: 768px) {
    .hero {
      padding: 8rem 0 6rem;
    }
    
    .hero-grid {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: 3rem;
    }
    
    .hero-subtitle {
      font-size: 1.5rem;
    }
  }
  
  @media (min-width: 1024px) {
    .hero {
      padding: 10rem 0 8rem;
    }
    
    .hero-grid {
      gap: 4rem;
    }
  }
  
  @media (max-width: 767px) {
    .hero {
      padding: 4rem 0 3rem;
    }
    
    .hero-title {
      font-size: 2.5rem;
    }
    
    .hero-subtitle {
      font-size: 1.125rem;
    }
    
    .hero-cta {
      flex-direction: column;
    }
    
    .btn {
      width: 100%;
      justify-content: center;
    }
    
    .trust-stats {
      justify-content: space-between;
    }
    
    .stat-divider {
      display: none;
    }
    
    .floating-card {
      display: none; /* Hide on mobile for cleaner look */
    }

    .hero-visual {
      justify-content: center;
    }

    .hero-image-wrapper {
      margin: 0 auto;
      max-width: 100%;
    }
  }
  
  /* ──────────────────────────────────────────────────────────────────
     BACKGROUND DECORATION (Subtle pattern)
     ────────────────────────────────────────────────────────────────── */
  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  
  .hero > .container {
    position: relative;
    z-index: 1;
  }
</style>