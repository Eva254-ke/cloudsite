---
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  image = '/favicon.svg',
  canonical,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://cloudbridge.network';
const currentUrl = canonical || Astro.url.href;
const imageUrl = new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | CloudBridge Networks</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={currentUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content="CloudBridge Networks" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

  </head>
  <body class="page-shell">
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <CookieBanner />
  </body>
</html>

<style is:global>
  :root {
    --color-background: #f6f9fc;
    --color-surface: #ffffff;
    --color-surface-strong: #eef3f8;
    --color-text: #0a0a0a;
    --color-muted: rgba(10, 10, 10, 0.72);
    --color-subtle: rgba(10, 10, 10, 0.48);
    --color-border: rgba(15, 23, 42, 0.08);
    --color-border-strong: rgba(15, 23, 42, 0.16);
    --color-accent: #0f6fff;
    --container-width: 1240px;
    --space-4: 4px;
    --space-8: 8px;
    --space-12: 12px;
    --space-16: 16px;
    --space-24: 24px;
    --space-32: 32px;
    --space-48: 48px;
    --space-64: 64px;
    --space-96: 96px;
    --radius-control: 4px;
    --radius-card: 8px;
    color-scheme: light;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: auto;
    background: var(--color-background);
  }

  body {
    min-height: 100vh;
    background: var(--color-background);
    color: var(--color-text);
    line-height: 1.5;
    text-wrap: pretty;
  }

  .page-shell {
    animation: page-fade 300ms ease-out;
  }

  img,
  svg,
  picture {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
    color: inherit;
  }

  main {
    display: block;
  }

  section {
    padding: var(--space-64) 0;
  }

  .section-surface {
    background: var(--color-surface);
  }

  .section-surface-strong {
    background: var(--color-surface-strong);
  }

  section + section {
    border-top: 1px solid var(--color-border);
  }

  h1,
  h2,
  h3 {
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text);
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6rem);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  h3 {
    font-size: 1.5rem;
  }

  p,
  li,
  dd {
    color: var(--color-muted);
  }

  ul,
  ol {
    padding-left: var(--space-24);
  }

  strong {
    color: var(--color-text);
  }

  .container {
    width: min(calc(100% - 32px), var(--container-width));
    margin: 0 auto;
  }

  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-surface);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    min-height: 44px;
    padding: var(--space-12) var(--space-16);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }

  .btn-primary {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: #ffffff;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    opacity: 0.92;
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background: var(--color-surface-strong);
  }

  .btn-block {
    width: 100%;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .section-heading,
  .page-heading {
    max-width: 860px;
  }

  .section-heading {
    margin-bottom: var(--space-32);
  }

  .page-heading {
    margin-bottom: var(--space-32);
  }

  .section-heading .eyebrow,
  .page-heading .eyebrow {
    margin-bottom: var(--space-12);
  }

  .section-heading h2,
  .page-heading h1 {
    margin-bottom: var(--space-16);
  }

  .section-heading p,
  .page-heading p {
    max-width: 720px;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: var(--space-16);
    z-index: 100;
    padding: var(--space-12) var(--space-16);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    background: var(--color-surface);
    text-decoration: none;
  }

  .skip-link:focus {
    left: var(--space-16);
  }

  label {
    display: block;
    margin-bottom: var(--space-8);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    background: var(--color-surface);
    padding: var(--space-12);
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--color-subtle);
  }

  .media-frame {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-background);
  }

  img[loading='lazy'] {
    content-visibility: auto;
  }

  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @keyframes page-fade {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-shell {
      animation: none;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-background: #0a0a0a;
      --color-surface: #141414;
      --color-surface-strong: #1a1a1a;
      --color-text: #ffffff;
      --color-muted: rgba(255, 255, 255, 0.74);
      --color-subtle: rgba(255, 255, 255, 0.52);
      --color-border: rgba(255, 255, 255, 0.12);
      --color-border-strong: rgba(255, 255, 255, 0.2);
      --color-accent: #5b8dff;
      color-scheme: dark;
    }
  }

  @media (max-width: 767px) {
    section {
      padding: var(--space-48) 0;
    }
  }
</style>
