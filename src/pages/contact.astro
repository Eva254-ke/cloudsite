---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact"
  description="Talk to CloudBridge Networks about satellite connectivity, African network infrastructure, billing systems, or managed operations support."
  canonical="https://cloudbridge.network/contact"
>
  <Header />

  <main id="main">
    <section>
      <div class="container">
        <div class="page-heading">
          <p class="eyebrow">Talk to us</p>
          <h1>Tell us about the site and the connection problem.</h1>
          <p>
            Send the project details straight to our team. We can review the location,
            coverage needs, rollout constraints, billing setup, and the support model
            required after launch.
          </p>
        </div>

        <div class="contact-grid">
          <section class="card contact-card contact-form-card">
            <div class="contact-form-header">
              <h2>Send your inquiry</h2>
              <p class="contact-intro">This goes straight to the CloudBridge team. No draft email opens.</p>
            </div>

            <form
              class="contact-form"
              action="https://formsubmit.co/hello@cloudbridge.network"
              method="POST"
              accept-charset="UTF-8"
            >
              <input type="hidden" name="_subject" value="CloudBridge infrastructure inquiry" />
              <input type="hidden" name="_next" value="https://cloudbridge.network/contact-success" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="text" name="_honey" class="form-honeypot" tabindex="-1" autocomplete="off" />
              <input
                type="hidden"
                name="_autoresponse"
                value="Thanks for contacting CloudBridge Networks. We have received your inquiry and will review the site details and follow up with you."
              />

              <div class="contact-form-grid">
                <div class="form-row">
                  <label for="name">Full name</label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    placeholder="Your full name"
                    autocomplete="name"
                    required
                  />
                </div>

                <div class="form-row">
                  <label for="email">Work email</label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    placeholder="you@organization.com"
                    autocomplete="email"
                    inputmode="email"
                    required
                  />
                </div>

                <div class="form-row">
                  <label for="phone">Phone</label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    placeholder="+254 ..."
                    autocomplete="tel"
                    inputmode="tel"
                  />
                </div>

                <div class="form-row">
                  <label for="company">Organization</label>
                  <input
                    id="company"
                    name="organization"
                    type="text"
                    placeholder="Hospital, business, NGO, county office, or company"
                    autocomplete="organization"
                  />
                </div>

                <div class="form-row">
                  <label for="facility">Facility or site type</label>
                  <select id="facility" name="facility_type" required>
                    <option value="">Select one</option>
                    <option>Hospital or clinic</option>
                    <option>School or institution</option>
                    <option>Business site</option>
                    <option>Community or remote facility</option>
                    <option>Government or county site</option>
                    <option>Other</option>
                  </select>
                </div>

                <div class="form-row">
                  <label for="location">Site location</label>
                  <input
                    id="location"
                    name="site_location"
                    type="text"
                    placeholder="Town, county, or region"
                    autocomplete="address-level2"
                    required
                  />
                </div>

                <div class="form-row form-row-wide">
                  <label for="support">What do you need?</label>
                  <select id="support" name="support_needed" required>
                    <option value="">Select one</option>
                    <option>Satellite infrastructure only</option>
                    <option>Infrastructure and site distribution</option>
                    <option>Infrastructure, billing, and operations support</option>
                    <option>Reliability upgrade for an existing site</option>
                    <option>Not sure yet</option>
                  </select>
                </div>

                <div class="form-row form-row-wide">
                  <label for="message">Project details</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="7"
                    placeholder="Tell us about the site, the connectivity issue, the parts of the facility that need coverage, and anything urgent we should know."
                    enterkeyhint="send"
                    aria-describedby="contact-note"
                    required
                  ></textarea>
                </div>
              </div>

              <div class="contact-actions">
                <button type="submit" class="btn btn-primary btn-block">Send inquiry</button>
                <p id="contact-note" class="contact-note">
                  Your message is sent directly to
                  <a href="mailto:hello@cloudbridge.network">hello@cloudbridge.network</a>.
                </p>
              </div>
            </form>
          </section>

          <aside class="card contact-card contact-info-card">
            <h2>Contact details</h2>
            <div class="contact-stack">
              <div>
                <p class="contact-label">Email</p>
                <a href="mailto:hello@cloudbridge.network">hello@cloudbridge.network</a>
              </div>
              <div>
                <p class="contact-label">Phone</p>
                <a href="tel:+254742939094">+254 742 939 094</a>
              </div>
              <div>
                <p class="contact-label">Location</p>
                <p>Nairobi, Kenya</p>
              </div>
            </div>

            <div class="contact-tips">
              <h3>Useful first details</h3>
              <ul>
                <li>The facility type and location</li>
                <li>Whether the site already has connectivity</li>
                <li>The parts of the building that need coverage</li>
                <li>Whether you also need billing or managed operations support</li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-heading {
    max-width: 680px;
    margin-bottom: var(--space-24);
  }

  .page-heading h1 {
    max-width: 560px;
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.08;
  }

  .page-heading p:last-child {
    max-width: 560px;
  }

  .contact-grid {
    display: grid;
    gap: var(--space-16);
  }

  .contact-card {
    padding: var(--space-16);
  }

  .contact-card h2 {
    margin-bottom: var(--space-12);
    font-size: 1.5rem;
  }

  .contact-form-header {
    margin-bottom: var(--space-24);
  }

  .contact-intro {
    max-width: 34rem;
  }

  .contact-form {
    display: grid;
    gap: var(--space-16);
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .contact-form-grid {
    display: grid;
    gap: var(--space-12);
  }

  .form-row {
    display: grid;
    gap: var(--space-8);
  }

  .form-row-wide {
    grid-column: 1 / -1;
  }

  .contact-actions {
    display: grid;
    gap: var(--space-12);
  }

  .contact-note {
    font-size: 0.9rem;
    color: var(--color-subtle);
  }

  .contact-note a {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .contact-stack {
    display: grid;
    gap: var(--space-16);
  }

  .contact-label {
    margin-bottom: var(--space-4);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .contact-tips {
    margin-top: var(--space-24);
    padding-top: var(--space-24);
    border-top: 1px solid var(--color-border);
  }

  .contact-tips h3 {
    margin-bottom: var(--space-12);
    font-size: 1.25rem;
  }

  .contact-tips ul {
    display: grid;
    gap: var(--space-8);
  }

  @media (min-width: 760px) {
    .contact-card {
      padding: var(--space-24);
    }

    .contact-form-grid {
      gap: var(--space-16);
    }
  }

  @media (min-width: 900px) {
    .contact-form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 980px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
      align-items: start;
    }

    .contact-info-card {
      position: sticky;
      top: var(--space-24);
    }
  }

  @media (max-width: 767px) {
    .page-heading h1 {
      font-size: clamp(1.9rem, 9vw, 2.5rem);
    }
  }
</style>
