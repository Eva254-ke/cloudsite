---
// contact.astro - Contact page
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with CloudBridge Networks. Nairobi-based team supporting WiFi entrepreneurs across Africa."
  canonical="https://cloudbridge.network/contact"
>
  <Header />
  
  <main>
    <section class="contact-section">
      <div class="container">
        <div class="contact-hero">
          <h1>Contact CloudBridge Networks</h1>
          <p>
            Talk to our team about infrastructure deployment, managed network services,
            platform licensing, and strategic partnerships across Africa.
          </p>
        </div>
        
        <div class="contact-layout">
          <aside class="contact-info">
            <article class="info-card">
              <h2>Office</h2>
              <p>Nairobi, Kenya</p>
            </article>

            <article class="info-card">
              <h2>Email</h2>
              <p>
                <a href="mailto:hello@cloudbridge.network">hello@cloudbridge.network</a>
              </p>
            </article>

            <article class="info-card">
              <h2>Phone / WhatsApp</h2>
              <p>
                <a href="tel:+254742939094">+254 742 939 094</a>
              </p>
            </article>

            <article class="info-card">
              <h2>Social</h2>
              <div class="social-links">
                <a href="https://twitter.com/cloudbridgeke" target="_blank" rel="noopener">Twitter</a>
                <a href="https://linkedin.com/company/cloudbridge-networks" target="_blank" rel="noopener">LinkedIn</a>
              </div>
            </article>
          </aside>
          
          <section class="contact-form-card">
            <h2>Send a Message</h2>
            <p class="form-intro">Share your project goals and our team will get back to you promptly.</p>

            <form class="contact-form" novalidate>
              <div class="form-row">
                <label for="name">Full Name</label>
                <input id="name" type="text" class="form-input" placeholder="Your full name" />
              </div>

              <div class="form-row">
                <label for="email">Business Email</label>
                <input id="email" type="email" class="form-input" placeholder="you@company.com" />
              </div>

              <div class="form-row">
                <label for="company">Company Name</label>
                <input id="company" type="text" class="form-input" placeholder="Your company" />
              </div>

              <div class="form-row">
                <label for="message">Message</label>
                <textarea id="message" class="form-input" rows="5" placeholder="Tell us about your requirements"></textarea>
              </div>

              <button type="button" class="btn btn-primary btn-full contact-submit">
                Send Inquiry
              </button>
            </form>

            <p class="form-note">
              Prefer email? Reach us directly at <a href="mailto:hello@cloudbridge.network">hello@cloudbridge.network</a>
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .contact-section {
    padding: 4rem 0;
    background: var(--color-gray-50);
  }

  .contact-hero {
    max-width: 760px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .contact-hero p {
    font-size: 1.05rem;
    margin-bottom: 0;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }

  .contact-info {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .info-card {
    background: white;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--border-radius-lg);
    padding: 1rem;
  }

  .info-card h2 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .info-card p {
    margin: 0;
    color: var(--color-gray-600);
  }

  .info-card a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .contact-form-card {
    background: white;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
  }

  .contact-form-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }

  .form-intro {
    font-size: 0.95rem;
    margin-bottom: 1rem;
    color: var(--color-gray-600);
  }

  .contact-form {
    display: grid;
    gap: 0.75rem;
  }

  .form-row label {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-700);
  }

  .form-input {
    width: 100%;
    padding: 0.8rem 0.95rem;
    border: 1.5px solid var(--color-gray-300);
    border-radius: var(--border-radius);
    font-size: 1rem;
    transition: var(--transition);
    background: white;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .contact-submit {
    margin-top: 0.35rem;
  }

  .form-note {
    margin: 0.9rem 0 0;
    font-size: 0.86rem;
    color: var(--color-gray-600);
    text-align: center;
  }

  .form-note a {
    font-weight: 600;
  }

  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: 0.9fr 1.35fr;
      gap: 1.25rem;
    }
  }

  @media (max-width: 767px) {
    .contact-section {
      padding: 3rem 0;
    }

    .contact-hero p {
      font-size: 1rem;
    }
  }
</style>