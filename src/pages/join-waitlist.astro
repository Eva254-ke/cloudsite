---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Partner With Us"
  description="CloudBridge is operating now. Use this page if you came through an older waitlist link and want to discuss an African network infrastructure project."
  canonical="https://cloudbridge.network/join-waitlist"
>
  <Header />

  <main id="main">
    <section>
      <div class="container">
        <div class="page-heading">
          <p class="eyebrow">Partner with us</p>
          <h1>CloudBridge is already operating.</h1>
          <p>
            This page stays live for older waitlist links. If you need satellite-based network
            infrastructure, billing support, or managed operations, send us the site details.
          </p>
        </div>

        <div class="partner-grid">
          <article class="card partner-card">
            <h2>Infrastructure projects</h2>
            <p>Connectivity planning for hospitals, institutions, businesses, and critical facilities.</p>
          </article>

          <article class="card partner-card">
            <h2>Remote deployments</h2>
            <p>Satellite-backed internet for sites where terrestrial options are weak or unavailable.</p>
          </article>

          <article class="card partner-card">
            <h2>Billing and operations</h2>
            <p>Support for access control, billing workflows, and the operating layer after rollout.</p>
          </article>
        </div>

        <div class="card partner-cta">
          <div>
            <p class="eyebrow">Start here</p>
            <h2>Use the contact page to send the project details.</h2>
            <p>We can follow up on scope, site conditions, and the infrastructure or operations problem you need solved.</p>
          </div>

          <div class="partner-actions">
            <a href="/contact" class="btn btn-primary">Contact the team</a>
            <a href="/" class="btn btn-secondary">Back to home</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .partner-grid {
    display: grid;
    gap: var(--space-16);
  }

  .partner-card {
    padding: var(--space-24);
  }

  .partner-card h2 {
    margin-bottom: var(--space-12);
    font-size: 1.5rem;
  }

  .partner-cta {
    display: grid;
    gap: var(--space-24);
    margin-top: var(--space-32);
    padding: var(--space-32);
  }

  .partner-cta .eyebrow {
    margin-bottom: var(--space-12);
  }

  .partner-cta h2 {
    margin-bottom: var(--space-16);
  }

  .partner-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .partner-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .partner-cta {
      grid-template-columns: minmax(0, 1.5fr) auto;
      align-items: center;
    }

    .partner-actions {
      justify-content: flex-end;
    }
  }
</style>
