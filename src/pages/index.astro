---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Satellite-based network infrastructure across Africa"
  description="CloudBridge Networks builds Africa's satellite-based network infrastructure for hospitals, institutions, businesses, and remote sites, including billing and operations support."
>
  <Header />

  <main id="main">
    <Hero />

    <section id="mission">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Mission</p>
          <h2>Internet infrastructure for the sites that keep work moving.</h2>
          <p>
            We build around continuity. That means looking beyond installation and making sure
            the network, billing, and support layers can keep serving the site over time.
          </p>
        </div>

        <div class="mission-grid">
          <article class="card mission-card">
            <p class="mission-index">01</p>
            <h3>Backhaul that reaches hard sites</h3>
            <p>Satellite links for facilities beyond the practical reach of stable terrestrial connectivity.</p>
          </article>

          <article class="card mission-card">
            <p class="mission-index">02</p>
            <h3>Site coverage that makes sense</h3>
            <p>Planning for the full facility or campus, not just the link arriving at the roof.</p>
          </article>

          <article class="card mission-card">
            <p class="mission-index">03</p>
            <h3>Operations after deployment</h3>
            <p>Billing, monitoring, access flows, and support so the site remains usable once it is live.</p>
          </article>
        </div>

        <div class="mission-visual card" aria-label="CloudBridge delivery stack">
          <div class="mission-visual-header">
            <p class="eyebrow">Delivery stack</p>
            <h3>One operating model from backhaul to long-term support.</h3>
            <p>
              Every site is planned as a working system. The link, the local network,
              billing, and the support layer are designed to stay connected.
            </p>
          </div>

          <div class="mission-track" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="mission-flow">
            <article class="mission-step">
              <div class="mission-step-top">
                <p class="mission-step-index">01</p>
                <p class="mission-step-label">Network layer</p>
              </div>
              <h3>Backhaul</h3>
              <p>Satellite capacity for remote and underserved sites.</p>
              <div class="mission-step-rows">
                <div>
                  <span>Role</span>
                  <strong>Primary route</strong>
                </div>
                <div>
                  <span>Coverage</span>
                  <strong>Hard-to-reach locations</strong>
                </div>
              </div>
            </article>

            <article class="mission-step">
              <div class="mission-step-top">
                <p class="mission-step-index">02</p>
                <p class="mission-step-label">Site layer</p>
              </div>
              <h3>Distribution</h3>
              <p>Coverage across wards, offices, branches, campuses, and shared spaces.</p>
              <div class="mission-step-rows">
                <div>
                  <span>Scope</span>
                  <strong>Facility-wide rollout</strong>
                </div>
                <div>
                  <span>Output</span>
                  <strong>Usable local network</strong>
                </div>
              </div>
            </article>

            <article class="mission-step">
              <div class="mission-step-top">
                <p class="mission-step-index">03</p>
                <p class="mission-step-label">Service layer</p>
              </div>
              <h3>Operations</h3>
              <p>Billing, access control, monitoring, and service workflows tied to the live network.</p>
              <div class="mission-step-rows">
                <div>
                  <span>Handles</span>
                  <strong>Billing and access</strong>
                </div>
                <div>
                  <span>Connects</span>
                  <strong>Live service rules</strong>
                </div>
              </div>
            </article>

            <article class="mission-step">
              <div class="mission-step-top">
                <p class="mission-step-index">04</p>
                <p class="mission-step-label">Support layer</p>
              </div>
              <h3>Support</h3>
              <p>Continuity follow-up and practical response after the site is live.</p>
              <div class="mission-step-rows">
                <div>
                  <span>Focus</span>
                  <strong>Issue response</strong>
                </div>
                <div>
                  <span>Outcome</span>
                  <strong>Long-term continuity</strong>
                </div>
              </div>
            </article>
          </div>

          <p class="mission-visual-summary">
            One team covers infrastructure, billing, monitoring, and ongoing support.
          </p>
        </div>
      </div>
    </section>

    <Features />
    <Pricing />

    <section>
      <div class="container">
        <div class="card closing-card">
          <div class="closing-copy">
            <p class="eyebrow">Next step</p>
            <h2>Tell us about the site, the location, and the uptime problem.</h2>
            <p>
              We can talk through a new rollout, a reliability upgrade, or a site that needs
              satellite connectivity plus billing and operational support under one team.
            </p>
          </div>

          <div class="closing-actions">
            <a href="/contact" class="btn btn-primary">Start a conversation</a>
            <a href="/about" class="btn btn-secondary">About CloudBridge</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .mission-grid {
    display: grid;
    gap: var(--space-16);
  }

  .mission-card {
    padding: var(--space-24);
    background: var(--color-surface);
  }

  .mission-index {
    margin-bottom: var(--space-12);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .mission-card h3 {
    margin-bottom: var(--space-12);
  }

  .mission-visual {
    margin-top: var(--space-32);
    padding: var(--space-24);
    display: grid;
    gap: var(--space-24);
    background: var(--color-surface);
  }

  .mission-visual-header {
    display: grid;
    gap: var(--space-12);
    max-width: 760px;
  }

  .mission-visual-header h3 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.08;
  }

  .mission-track {
    display: none;
    position: relative;
    height: 20px;
  }

  .mission-track::before {
    content: '';
    position: absolute;
    top: 9px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-border-strong);
  }

  .mission-track span {
    position: absolute;
    top: 0;
    width: 20px;
    height: 20px;
    border: 4px solid var(--color-accent);
    border-radius: 50%;
    background: var(--color-surface);
    transform: translateX(-50%);
  }

  .mission-track span:nth-child(1) {
    left: 12.5%;
  }

  .mission-track span:nth-child(2) {
    left: 37.5%;
  }

  .mission-track span:nth-child(3) {
    left: 62.5%;
  }

  .mission-track span:nth-child(4) {
    left: 87.5%;
  }

  .mission-flow {
    display: grid;
    gap: var(--space-12);
  }

  .mission-step {
    display: grid;
    gap: var(--space-16);
    padding: var(--space-24);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-surface-strong);
  }

  .mission-step-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-12);
    align-items: center;
  }

  .mission-step-index {
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .mission-step-label {
    color: var(--color-subtle);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .mission-step h3 {
    margin-bottom: var(--space-8);
    font-size: 1.25rem;
  }

  .mission-step-rows {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .mission-step-rows div {
    display: grid;
    gap: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .mission-step-rows span {
    color: var(--color-subtle);
    font-size: 0.875rem;
  }

  .mission-step-rows strong {
    font-size: 0.95rem;
  }

  .mission-visual-summary {
    padding: var(--space-16) var(--space-24);
    border-radius: var(--radius-card);
    background: var(--color-text);
    color: var(--color-surface);
    font-size: 1rem;
    font-weight: 600;
  }

  .closing-card {
    display: grid;
    gap: var(--space-24);
    padding: var(--space-32);
  }

  .closing-copy .eyebrow {
    margin-bottom: var(--space-12);
  }

  .closing-copy h2 {
    margin-bottom: var(--space-16);
  }

  .closing-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .mission-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .mission-track {
      display: block;
    }

    .mission-step {
      min-height: 250px;
    }

    .mission-step-rows div {
      display: flex;
      justify-content: space-between;
      gap: var(--space-16);
    }

    .mission-step-rows strong {
      max-width: 14rem;
      text-align: right;
    }

    .closing-card {
      grid-template-columns: minmax(0, 1.45fr) auto;
      align-items: center;
    }

    .closing-actions {
      justify-content: flex-end;
    }
  }

  @media (min-width: 1180px) {
    .mission-flow {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
