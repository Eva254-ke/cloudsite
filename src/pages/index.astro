---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Building Connected Africa"
  description="CloudBridge Networks provides enterprise-grade WiFi billing, M-Pesa integration, and MikroTik management for hotspot operators across Africa."
>
  <Header />
  
  <main>
    <Hero />
    <Features />
    <Pricing />
    
    <!-- Final CTA Section -->
    <section class="py-20 bg-primary text-white text-center">
      <div class="container">
        <h2 class="text-white mb-4">Ready to Build With Us?</h2>
        <p class="text-xl opacity-90 mb-8 max-w-2xl mx-auto">
          Partner with CloudBridge Networks to deploy next-generation connectivity and infrastructure across Africa.
        </p>
        <a href="/contact" class="btn bg-white text-primary hover:bg-gray-100">
          Contact Us
        </a>
        <p class="mt-4 text-sm opacity-75">
          Already launched • Trusted by ISPs & businesses
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>