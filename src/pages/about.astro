---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About"
  description="CloudBridge Networks builds Africa's satellite-based network infrastructure for hospitals, institutions, businesses, and remote sites."
  canonical="https://cloudbridge.network/about"
>
  <Header />

  <main id="main">
    <section>
      <div class="container">
        <div class="page-heading">
          <p class="eyebrow">About CloudBridge</p>
          <h1>We build the satellite-backed networks that keep important sites online.</h1>
          <p>
            CloudBridge started from a practical need: too many important sites across Africa still
            work with weak connectivity, unstable links, or no realistic terrestrial option at all.
          </p>
        </div>

        <div class="about-grid">
          <article class="card about-card">
            <h2>What the company is built to do</h2>
            <p>
              We focus on satellite-backed internet infrastructure for hospitals, institutions,
              businesses, community sites, and remote facilities where stable connectivity directly affects daily work.
            </p>
            <p>
              That means planning beyond a basic install. We think through site conditions,
              internal distribution, resilience, billing requirements, and the support needed after a site goes live.
            </p>
          </article>

          <aside class="card about-card facts-card">
            <h2>Company facts</h2>
            <dl>
              <div class="fact-row">
                <dt>Headquarters</dt>
                <dd>Nairobi, Kenya</dd>
              </div>
              <div class="fact-row">
                <dt>Founded</dt>
                <dd>2024</dd>
              </div>
              <div class="fact-row">
                <dt>Registration</dt>
                <dd>BN-Y6S98MJB</dd>
              </div>
              <div class="fact-row">
                <dt>Focus</dt>
                <dd>Satellite infrastructure, billing systems, and managed network operations</dd>
              </div>
            </dl>
          </aside>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">How we work</p>
          <h2>We keep the work direct.</h2>
          <p>Projects are shaped by site conditions, operational risk, and long-term usability.</p>
        </div>

        <div class="principles-grid">
          <article class="card principle-card">
            <h3>Plan around uptime</h3>
            <p>For hospitals, institutions, and businesses, reliable connectivity is part of how the site functions.</p>
          </article>

          <article class="card principle-card">
            <h3>Build for remote realities</h3>
            <p>We account for access limits, maintenance windows, and the practical constraints of underserved areas.</p>
          </article>

          <article class="card principle-card">
            <h3>Stay involved after launch</h3>
            <p>Support matters after deployment, not only during installation week.</p>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="card about-cta">
          <div>
            <p class="eyebrow">Work with us</p>
            <h2>Need a site or network project reviewed?</h2>
            <p>Share the site details and we can talk through the infrastructure, billing, and operational needs.</p>
          </div>
          <a href="/contact" class="btn btn-primary">Contact CloudBridge</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-heading {
    max-width: 760px;
    margin-bottom: var(--space-24);
  }

  .page-heading h1 {
    max-width: 700px;
    font-size: clamp(2.25rem, 5vw, 3.8rem);
    line-height: 1.06;
  }

  .page-heading p:last-child {
    max-width: 620px;
  }

  .about-grid,
  .principles-grid {
    display: grid;
    gap: var(--space-16);
  }

  .about-card,
  .principle-card {
    padding: var(--space-24);
  }

  .about-card h2,
  .principle-card h3 {
    margin-bottom: var(--space-12);
  }

  .about-card p + p {
    margin-top: var(--space-16);
  }

  .facts-card dl {
    margin-top: var(--space-16);
  }

  .fact-row {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-border);
  }

  .fact-row:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .fact-row dt {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .fact-row dd {
    color: var(--color-text);
  }

  .about-cta {
    display: grid;
    gap: var(--space-24);
    padding: var(--space-32);
  }

  .about-cta .eyebrow {
    margin-bottom: var(--space-12);
  }

  .about-cta h2 {
    margin-bottom: var(--space-16);
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
    }

    .principles-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .about-cta {
      grid-template-columns: minmax(0, 1.5fr) auto;
      align-items: center;
    }
  }

  @media (max-width: 767px) {
    .page-heading h1 {
      font-size: clamp(2rem, 10vw, 2.8rem);
    }
  }
</style>
